  "flow": {
    "triggers": [
      {
        "title": {
          "en": "Charging started"
        },
        "tokens": [
          {
            "name": "battery",
            "type": "number",
            "title": {
              "en": "Battery level"
            },
            "example": 75
          }
        ],
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=leaf|leaf-ze1"
          }
        ],
        "id": "charging_started"
      },
      {
        "title": {
          "en": "Charging stopped"
        },
        "tokens": [
          {
            "name": "battery",
            "type": "number",
            "title": {
              "en": "Battery level"
            },
            "example": 95
          }
        ],
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=leaf|leaf-ze1"
          }
        ],
        "id": "charging_stopped"
      },
      {
        "title": {
          "en": "Climate control started"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=leaf|leaf-ze1"
          }
        ],
        "id": "climate_started"
      },
      {
        "title": {
          "en": "Climate control stopped"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=leaf|leaf-ze1"
          }
        ],
        "id": "climate_stopped"
      },
      {
        "title": {
          "en": "Connected to charger"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=leaf|leaf-ze1"
          }
        ],
        "id": "connected_to_charger"
      },
      {
        "title": {
          "en": "Vehicle data was refreshed"
        },
        "hint": {
          "en": "Triggered when fresh data is received from the vehicle after a wake-up"
        },
        "tokens": [
          {
            "name": "battery",
            "type": "number",
            "title": {
              "en": "Battery %"
            }
          },
          {
            "name": "range",
            "type": "number",
            "title": {
              "en": "Range (km)"
            }
          }
        ],
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=leaf|leaf-ze1"
          }
        ],
        "id": "data_refreshed"
      },
      {
        "title": {
          "en": "Disconnected from charger"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=leaf|leaf-ze1"
          }
        ],
        "id": "disconnected_from_charger"
      }
    ],
    "conditions": [
      {
        "title": {
          "en": "Battery level is above"
        },
        "titleFormatted": {
          "en": "Battery level is above [[percentage]]%"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=leaf|leaf-ze1"
          },
          {
            "type": "range",
            "name": "percentage",
            "min": 0,
            "max": 100,
            "step": 1,
            "label": "%",
            "labelMultiplier": 1,
            "labelDecimals": 0
          }
        ],
        "id": "battery_above"
      },
      {
        "title": {
          "en": "Climate control is !{{on|off}}"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=leaf|leaf-ze1"
          }
        ],
        "id": "climate_is_on"
      },
      {
        "title": {
          "en": "Is !{{charging|not charging}}"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=leaf|leaf-ze1"
          }
        ],
        "id": "is_charging"
      },
      {
        "title": {
          "en": "Is !{{connected|not connected}} to charger"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=leaf|leaf-ze1"
          }
        ],
        "id": "is_connected"
      }
    ],
    "actions": [
      {
        "title": {
          "en": "Refresh all vehicle data"
        },
        "hint": {
          "en": "Wake the car and fetch fresh battery, climate, and location data. This may take up to 90 seconds."
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=leaf|leaf-ze1"
          }
        ],
        "id": "refresh_all_data"
      },
      {
        "title": {
          "en": "Refresh battery status"
        },
        "hint": {
          "en": "Wake the vehicle and request fresh battery data (2019+ models only)"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=leaf-ze1"
          }
        ],
        "id": "refresh_battery"
      },
      {
        "title": {
          "en": "Start charging"
        },
        "hint": {
          "en": "Send command to start charging (pre-2019 models only)"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=leaf"
          }
        ],
        "id": "start_charging"
      },
      {
        "title": {
          "en": "Start climate control"
        },
        "titleFormatted": {
          "en": "Start climate control at [[temperature]]°C"
        },
        "hint": {
          "en": "Start climate control at a specific temperature (2019+ models only)"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=leaf-ze1"
          },
          {
            "type": "range",
            "name": "temperature",
            "min": 16,
            "max": 28,
            "step": 1,
            "label": "°C",
            "labelMultiplier": 1,
            "labelDecimals": 0,
            "value": 21
          }
        ],
        "id": "start_climate"
      },
      {
        "title": {
          "en": "Start climate control"
        },
        "hint": {
          "en": "Start climate control (pre-2019 models - temperature not supported)"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=leaf"
          }
        ],
        "id": "start_climate_legacy"
      },
      {
        "title": {
          "en": "Start persistent climate"
        },
        "titleFormatted": {
          "en": "Start persistent climate at [[temperature]]°C"
        },
        "hint": {
          "en": "Start climate control that auto-restarts if it stops, until max time or vehicle moves (2019+ models only)"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=leaf-ze1"
          },
          {
            "name": "temperature",
            "type": "number",
            "min": 16,
            "max": 26,
            "step": 1,
            "placeholder": {
              "en": "21"
            },
            "title": {
              "en": "Temperature"
            }
          }
        ],
        "id": "start_persistent_climate"
      },
      {
        "title": {
          "en": "Stop climate control"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=leaf|leaf-ze1"
          }
        ],
        "id": "stop_climate"
      },
      {
        "title": {
          "en": "Stop persistent climate"
        },
        "hint": {
          "en": "Stop persistent climate mode and turn off climate control (2019+ models only)"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=leaf-ze1"
          }
        ],
        "id": "stop_persistent_climate"
      }
    ]
  },
