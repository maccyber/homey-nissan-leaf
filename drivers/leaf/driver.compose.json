  "pair": [
    {
      "id": "start"
    },
    {
      "id": "list_devices",
      "template": "list_devices",
      "navigation": {
        "next": "add_devices"
      },
      "options": {
        "singular": true
      }
    },
    {
      "id": "add_devices",
      "template": "add_devices"
    }
  ],
  "settings": [
    {
      "type": "group",
      "label": {
        "en": "Account",
        "no": "Konto"
      },
      "children": [
        {
          "id": "username",
          "type": "text",
          "label": {
            "en": "Email",
            "no": "E-post"
          },
          "value": "",
          "hint": {
            "en": "Your NissanConnect email address",
            "no": "Din NissanConnect e-postadresse"
          }
        },
        {
          "id": "password",
          "type": "password",
          "label": {
            "en": "Password",
            "no": "Passord"
          },
          "value": "",
          "hint": {
            "en": "Your NissanConnect password",
            "no": "Ditt NissanConnect passord"
          }
        },
        {
          "id": "regionCode",
          "type": "dropdown",
          "label": {
            "en": "Region",
            "no": "Region"
          },
          "value": "NE",
          "values": [
            { "id": "NE", "label": { "en": "Europe", "no": "Europa" } },
            { "id": "NCI", "label": { "en": "Canada", "no": "Canada" } },
            { "id": "NNA", "label": { "en": "USA", "no": "USA" } },
            { "id": "NMA", "label": { "en": "Australia", "no": "Australia" } },
            { "id": "NML", "label": { "en": "Japan", "no": "Japan" } }
          ],
          "hint": {
            "en": "Your Nissan region",
            "no": "Din Nissan-region"
          }
        }
      ]
    },
    {
      "type": "group",
      "label": {
        "en": "Polling",
        "no": "Polling"
      },
      "children": [
        {
          "id": "pollInterval",
          "type": "number",
          "label": {
            "en": "Poll interval (seconds)",
            "no": "Oppdateringsintervall (sekunder)"
          },
          "value": 240,
          "min": 60,
          "max": 3600,
          "hint": {
            "en": "How often to check vehicle status (default: 240 seconds / 4 minutes)",
            "no": "Hvor ofte kjøretøystatus sjekkes (standard: 240 sekunder / 4 minutter)"
          }
        }
      ]
    }
  ]
